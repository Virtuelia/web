---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import type { Country } from '@/lib/database.types';

const supabase = Astro.locals.supabase;
const user = Astro.locals.user;

// Fetch all countries with video counts
const { data: countries, error } = await supabase
  .from('countries')
  .select(`
    id,
    name,
    code,
    region,
    is_fantasy,
    cultural_notes,
    visual_palette,
    landmarks,
    research_status,
    created_at,
    updated_at
  `)
  .order('name');

// Get video counts for each country
const countriesList = await Promise.all(
  (countries as any[])?.map(async (country) => {
    const { count } = await supabase
      .from('videos')
      .select('*', { count: 'exact', head: true })
      .eq('country_id', country.id);

    return {
      ...country,
      videos_count: count || 0,
    };
  }) || []
);

// Helper to get flag emoji from country code
function getCountryEmoji(code: string | null): string {
  if (!code || code.length !== 2) return '🌍';
  const codePoints = Array.from(code.toUpperCase()).map((char) => 127397 + char.charCodeAt(0));
  return String.fromCodePoint(...codePoints);
}

const isAdmin = user?.user_metadata?.role === 'admin' || user?.user_metadata?.role === 'creator';
---

<DashboardLayout title="Countries">
  <!-- Header -->
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-[var(--color-v-dark)]" style="font-family: var(--font-display)">
        Countries
      </h1>
      <p class="text-[var(--color-v-gray)] mt-1">
        {countriesList.length} {countriesList.length === 1 ? 'country' : 'countries'} in library
      </p>
    </div>
    {isAdmin && (
      <button
        onclick="document.getElementById('addCountryModal').showModal()"
        class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-v-teal)] text-white rounded-lg font-medium hover:opacity-90 transition-opacity"
      >
        <span>+</span>
        <span>Add Country</span>
      </button>
    )}
  </div>

  {countriesList.length === 0 ? (
    <!-- Empty state -->
    <div class="bg-white rounded-xl border border-gray-100 p-12 text-center">
      <p class="text-[var(--color-v-gray)] mb-4">No countries yet.</p>
      {isAdmin && (
        <button
          onclick="document.getElementById('addCountryModal').showModal()"
          class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-v-teal)] text-white rounded-lg font-medium hover:opacity-90 transition-opacity"
        >
          Add first country
        </button>
      )}
    </div>
  ) : (
    <!-- Country grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {countriesList.map((country) => (
        <div class="bg-white rounded-xl border border-gray-100 p-6 hover:shadow-lg transition-shadow">
          <!-- Header -->
          <div class="flex items-start justify-between mb-4">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-2xl">{getCountryEmoji(country.code)}</span>
                <h3 class="text-lg font-bold text-[var(--color-v-dark)]">
                  {country.name}
                </h3>
              </div>
              {country.code && (
                <p class="text-xs text-[var(--color-v-gray)] ml-9">
                  {country.code.toUpperCase()}
                </p>
              )}
            </div>
          </div>

          <!-- Region -->
          {country.region && (
            <p class="text-sm text-[var(--color-v-gray)] mb-3">
              <span class="font-medium">Region:</span> {country.region}
            </p>
          )}

          <!-- Badges -->
          <div class="flex gap-2 mb-4 flex-wrap">
            {country.is_fantasy && (
              <span class="text-xs px-2 py-1 rounded-full font-medium bg-purple-100 text-purple-700">
                Fantasy
              </span>
            )}
            <span
              class:list={[
                'text-xs px-2 py-1 rounded-full font-medium',
                country.research_status === 'complete' ? 'bg-green-100 text-green-700' : country.research_status === 'in_progress' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-700',
              ]}
            >
              {country.research_status === 'complete' ? 'Complete' : country.research_status === 'in_progress' ? 'In Progress' : 'Not Started'}
            </span>
          </div>

          <!-- Cultural notes -->
          {country.cultural_notes && (
            <div class="mb-4 pb-4 border-b border-gray-100">
              <p class="text-xs font-semibold text-[var(--color-v-gray)] uppercase tracking-wide mb-1">
                Cultural Notes
              </p>
              <p class="text-sm text-[var(--color-v-dark)] line-clamp-2">
                {country.cultural_notes}
              </p>
            </div>
          )}

          <!-- Landmarks -->
          {country.landmarks && country.landmarks.length > 0 && (
            <div class="mb-4 pb-4 border-b border-gray-100">
              <p class="text-xs font-semibold text-[var(--color-v-gray)] uppercase tracking-wide mb-2">
                Landmarks
              </p>
              <div class="space-y-1">
                {country.landmarks.slice(0, 3).map((landmark: string) => (
                  <p class="text-sm text-[var(--color-v-dark)] flex items-start gap-2">
                    <span class="text-[var(--color-v-teal)] font-bold mt-0.5">•</span>
                    <span>{landmark}</span>
                  </p>
                ))}
                {country.landmarks.length > 3 && (
                  <p class="text-xs text-[var(--color-v-gray)] italic">
                    +{country.landmarks.length - 3} more
                  </p>
                )}
              </div>
            </div>
          )}

          <!-- Video count footer -->
          <div class="flex items-center justify-between pt-2">
            <span class="text-xs text-[var(--color-v-gray)]">
              <span class="font-semibold text-[var(--color-v-dark)]">{country.videos_count}</span>
              {country.videos_count === 1 ? ' video' : ' videos'}
            </span>
            {isAdmin && (
              <button
                onclick={`editCountry('${country.id}')`}
                class="text-xs text-[var(--color-v-teal)] hover:underline font-medium"
              >
                Edit
              </button>
            )}
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- Add/Edit modal -->
  {isAdmin && (
    <dialog id="addCountryModal" class="backdrop:bg-black/40 rounded-xl shadow-lg max-w-2xl">
      <div class="p-6">
        <h2 class="text-xl font-bold text-[var(--color-v-dark)] mb-4">
          Add New Country
        </h2>

        <form id="countryForm" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-sm font-medium text-[var(--color-v-dark)] block mb-1">
                Country Name
              </label>
              <input
                type="text"
                id="countryName"
                required
                placeholder="e.g., Japan"
                class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
              />
            </div>
            <div>
              <label class="text-sm font-medium text-[var(--color-v-dark)] block mb-1">
                Country Code
              </label>
              <input
                type="text"
                id="countryCode"
                maxlength="2"
                placeholder="JP"
                class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
              />
            </div>
          </div>

          <div>
            <label class="text-sm font-medium text-[var(--color-v-dark)] block mb-1">
              Region
            </label>
            <input
              type="text"
              id="countryRegion"
              placeholder="e.g., Asia"
              class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
            />
          </div>

          <div class="flex items-center gap-2">
            <input
              type="checkbox"
              id="countryFantasy"
              class="w-4 h-4 rounded border-gray-300"
            />
            <label for="countryFantasy" class="text-sm text-[var(--color-v-dark)]">
              This is a fantasy country
            </label>
          </div>

          <div>
            <label class="text-sm font-medium text-[var(--color-v-dark)] block mb-1">
              Research Status
            </label>
            <select
              id="countryResearchStatus"
              class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
            >
              <option value="not_started">Not Started</option>
              <option value="in_progress">In Progress</option>
              <option value="complete">Complete</option>
            </select>
          </div>

          <div>
            <label class="text-sm font-medium text-[var(--color-v-dark)] block mb-1">
              Cultural Notes
            </label>
            <textarea
              id="countryCulturalNotes"
              rows="3"
              placeholder="Add important cultural context..."
              class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
            ></textarea>
          </div>

          <div>
            <label class="text-sm font-medium text-[var(--color-v-dark)] block mb-1">
              Landmarks (comma-separated)
            </label>
            <input
              type="text"
              id="countryLandmarks"
              placeholder="Great Wall, Forbidden City, Summer Palace"
              class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
            />
          </div>

          <div class="flex gap-3 justify-end pt-4">
            <button
              type="button"
              onclick="document.getElementById('addCountryModal').close()"
              class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-[var(--color-v-dark)] hover:bg-gray-50 transition-colors"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="px-4 py-2 bg-[var(--color-v-teal)] text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
            >
              Save Country
            </button>
          </div>
        </form>
      </div>
    </dialog>
  )}

  <script define:vars={{ isAdmin }}>
    const form = document.getElementById('countryForm');

    if (form && isAdmin) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const landmarks = document
          .getElementById('countryLandmarks')
          .value.split(',')
          .map((l) => l.trim())
          .filter((l) => l);

        const countryData = {
          name: document.getElementById('countryName').value,
          code: document.getElementById('countryCode').value.toUpperCase(),
          region: document.getElementById('countryRegion').value,
          is_fantasy: document.getElementById('countryFantasy').checked,
          research_status: document.getElementById('countryResearchStatus').value,
          cultural_notes: document.getElementById('countryCulturalNotes').value,
          landmarks: landmarks,
        };

        try {
          const response = await fetch('/api/countries', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(countryData),
          });

          if (response.ok) {
            window.location.reload();
          } else {
            alert('Error saving country');
          }
        } catch (error) {
          console.error('Error:', error);
          alert('Error saving country');
        }
      });
    }
  </script>
</DashboardLayout>
