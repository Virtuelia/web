---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import type { Profile } from '@/lib/database.types';

const supabase = Astro.locals.supabase;
const user = Astro.locals.user;

// Get current user profile
const { data: currentProfile } = await supabase
  .from('profiles')
  .select('*')
  .eq('email', user?.email)
  .single();

// Get all team members
const { data: allProfiles } = await supabase
  .from('profiles')
  .select('*')
  .order('full_name');

const teamMembers = (allProfiles as Profile[]) || [];
const isAdmin = currentProfile?.role === 'admin' || currentProfile?.role === 'creator';
---

<DashboardLayout title="Settings">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--color-v-dark)]" style="font-family: var(--font-display)">
      Settings
    </h1>
    <p class="text-[var(--color-v-gray)] mt-1">Manage your profile and team</p>
  </div>

  <!-- User Profile Section -->
  <div class="bg-white rounded-xl border border-gray-100 mb-8 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-[var(--color-v-dark)]">User Profile</h2>
    </div>

    <div class="p-6">
      <div class="max-w-2xl">
        <!-- Current Profile Info -->
        <div class="space-y-4">
          <!-- Avatar -->
          <div>
            <p class="text-xs font-semibold text-[var(--color-v-gray)] uppercase tracking-wide mb-3">
              Avatar
            </p>
            <div class="flex items-center gap-4">
              {currentProfile?.avatar_url ? (
                <img src={currentProfile.avatar_url} alt="" class="w-16 h-16 rounded-lg object-cover" />
              ) : (
                <div class="w-16 h-16 rounded-lg bg-[var(--color-v-teal)] flex items-center justify-center text-2xl font-bold text-white">
                  {currentProfile?.full_name?.charAt(0).toUpperCase() || user?.email?.charAt(0).toUpperCase() || '?'}
                </div>
              )}
              <p class="text-sm text-[var(--color-v-gray)]">Avatar is managed by your authentication provider</p>
            </div>
          </div>

          <!-- Email -->
          <div>
            <label class="text-sm font-semibold text-[var(--color-v-gray)] uppercase tracking-wide block mb-1">
              Email
            </label>
            <input
              type="email"
              value={currentProfile?.email || ''}
              disabled
              class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-gray-50 text-[var(--color-v-dark)]"
            />
            <p class="text-xs text-[var(--color-v-gray)] mt-1">Email cannot be changed</p>
          </div>

          <!-- Full Name -->
          <div>
            <label class="text-sm font-semibold text-[var(--color-v-gray)] uppercase tracking-wide block mb-1">
              Full Name
            </label>
            <input
              type="text"
              id="fullNameInput"
              value={currentProfile?.full_name || ''}
              placeholder="Enter your full name"
              class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
            />
          </div>

          <!-- Role -->
          <div>
            <label class="text-sm font-semibold text-[var(--color-v-gray)] uppercase tracking-wide block mb-1">
              Role
            </label>
            <div class="px-3 py-2 border border-gray-200 rounded-lg text-sm bg-gray-50 text-[var(--color-v-dark)]">
              <span class="capitalize">
                {currentProfile?.role ? currentProfile.role.replace('_', ' ') : 'Unknown'}
              </span>
            </div>
            <p class="text-xs text-[var(--color-v-gray)] mt-1">Contact an administrator to change your role</p>
          </div>

          <!-- Save button -->
          <div class="pt-4">
            <button
              onclick="saveProfile()"
              class="px-4 py-2 bg-[var(--color-v-teal)] text-white rounded-lg text-sm font-medium hover:opacity-90 transition-opacity"
            >
              Save Changes
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Team Members Section -->
  {isAdmin && (
    <div class="bg-white rounded-xl border border-gray-100 mb-8 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-[var(--color-v-dark)]">
          Team Members
        </h2>
        <p class="text-sm text-[var(--color-v-gray)] mt-1">
          {teamMembers.length} {teamMembers.length === 1 ? 'member' : 'members'} in team
        </p>
      </div>

      {teamMembers.length === 0 ? (
        <div class="px-6 py-12 text-center">
          <p class="text-[var(--color-v-gray)]">No team members yet</p>
        </div>
      ) : (
        <div class="divide-y divide-gray-100">
          {teamMembers.map((member) => (
            <div class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
              <div class="flex items-center gap-4 flex-1">
                {member.avatar_url ? (
                  <img src={member.avatar_url} alt="" class="w-10 h-10 rounded-full object-cover" />
                ) : (
                  <div class="w-10 h-10 rounded-full bg-[var(--color-v-teal)] flex items-center justify-center text-sm font-bold text-white">
                    {member.full_name?.charAt(0).toUpperCase() || member.email?.charAt(0).toUpperCase() || '?'}
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-[var(--color-v-dark)]">
                    {member.full_name || 'No name'}
                  </p>
                  <p class="text-xs text-[var(--color-v-gray)] truncate">
                    {member.email}
                  </p>
                </div>
              </div>

              <!-- Role selector for admins -->
              {member.id === currentProfile?.id ? (
                <span class="text-sm text-[var(--color-v-gray)]">
                  <span class="px-3 py-1 rounded-full bg-[var(--color-v-teal)]/10 text-[var(--color-v-teal)] font-medium text-xs">
                    {member.role.replace('_', ' ')}
                  </span>
                </span>
              ) : (
                <select
                  value={member.role}
                  onchange={`updateMemberRole('${member.id}', this.value)`}
                  class="px-3 py-1 border border-gray-200 rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
                >
                  <option value="viewer">Viewer</option>
                  <option value="sel_reviewer">SEL Reviewer</option>
                  <option value="media_producer">Media Producer</option>
                  <option value="creator">Creator</option>
                  <option value="admin">Admin</option>
                </select>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  )}

  <!-- Project Info Section -->
  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h2 class="text-lg font-semibold text-[var(--color-v-dark)]">Project Information</h2>
    </div>

    <div class="p-6 max-w-2xl space-y-6">
      <div>
        <h3 class="font-semibold text-[var(--color-v-dark)] mb-2">
          About Virtuelia
        </h3>
        <p class="text-sm text-[var(--color-v-dark)] leading-relaxed">
          Virtuelia is a digital educational ecosystem for children aged 3-10, built to teach Social-Emotional Learning (SEL) through engaging stories featuring five memorable animal characters: Luna, Benny, Mia, Toby, and Zoe.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-[var(--color-v-dark)] mb-2">
          Core Values
        </h3>
        <ul class="space-y-2 text-sm text-[var(--color-v-dark)]">
          <li class="flex gap-2">
            <span class="text-[var(--color-v-teal)] font-bold">•</span>
            <span>Authentic storytelling that reflects real emotions and situations</span>
          </li>
          <li class="flex gap-2">
            <span class="text-[var(--color-v-teal)] font-bold">•</span>
            <span>Culturally diverse and inclusive content for a global audience</span>
          </li>
          <li class="flex gap-2">
            <span class="text-[var(--color-v-teal)] font-bold">•</span>
            <span>Evidence-based SEL competencies grounded in educational research</span>
          </li>
          <li class="flex gap-2">
            <span class="text-[var(--color-v-teal)] font-bold">•</span>
            <span>Collaborative, thoughtful production across teams</span>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-[var(--color-v-dark)] mb-2">
          Five SEL Competencies
        </h3>
        <ul class="space-y-2 text-sm text-[var(--color-v-dark)]">
          <li class="flex gap-2">
            <span style="color: #E8751A" class="font-bold">●</span>
            <span><span class="font-medium">Self-Awareness</span> — Understanding emotions and strengths</span>
          </li>
          <li class="flex gap-2">
            <span style="color: #8B5E3C" class="font-bold">●</span>
            <span><span class="font-medium">Self-Regulation</span> — Managing emotions and behaviors</span>
          </li>
          <li class="flex gap-2">
            <span style="color: #E91E8C" class="font-bold">●</span>
            <span><span class="font-medium">Social Skills</span> — Building positive relationships</span>
          </li>
          <li class="flex gap-2">
            <span style="color: #2D8B57" class="font-bold">●</span>
            <span><span class="font-medium">Responsible Decisions</span> — Making thoughtful choices</span>
          </li>
          <li class="flex gap-2">
            <span style="color: #D4A017" class="font-bold">●</span>
            <span><span class="font-medium">Social Awareness</span> — Empathy and perspective-taking</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <script define:vars={{ currentUserId: currentProfile?.id }}>
    async function saveProfile() {
      const fullName = document.getElementById('fullNameInput')?.value;

      if (!fullName?.trim()) {
        alert('Please enter your full name');
        return;
      }

      try {
        const response = await fetch('/api/profile', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ full_name: fullName }),
        });

        if (response.ok) {
          alert('Profile updated successfully');
          window.location.reload();
        } else {
          alert('Error updating profile');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error updating profile');
      }
    }

    async function updateMemberRole(memberId, newRole) {
      try {
        const response = await fetch('/api/team-members', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ member_id: memberId, role: newRole }),
        });

        if (response.ok) {
          alert('Team member role updated');
          // Optionally reload to reflect changes
          // window.location.reload();
        } else {
          alert('Error updating member role');
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Error updating member role');
      }
    }
  </script>
</DashboardLayout>
