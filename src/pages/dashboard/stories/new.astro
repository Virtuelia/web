---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { CHARACTER_LABELS, CHARACTER_COMPETENCY, COMPETENCY_LABELS } from '@/lib/helpers';
import type { CharacterName } from '@/lib/database.types';

const supabase = Astro.locals.supabase;
const videoId = Astro.url.searchParams.get('video_id');

// Fetch videos for the select
const { data: videos } = await supabase
  .from('videos')
  .select('id, title')
  .order('created_at', { ascending: false });

// If video_id is provided, fetch its details
let videoTitle = '';
if (videoId) {
  const { data: video } = await supabase
    .from('videos')
    .select('id, title')
    .eq('id', videoId)
    .single();
  videoTitle = video?.title || '';
}
---

<DashboardLayout title="Create Story">
  <!-- Back link -->
  <div class="mb-6">
    <a href="/dashboard/stories" class="text-sm text-[var(--color-v-teal)] hover:underline">
      ← Back to Stories
    </a>
  </div>

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--color-v-dark)]" style="font-family: var(--font-display)">
      Create New Story
    </h1>
    <p class="text-[var(--color-v-gray)] mt-1">Add a story to your video production</p>
  </div>

  <!-- Mode selector -->
  <div class="grid grid-cols-2 gap-4 max-w-3xl mb-8">
    <a
      href="/dashboard/stories/generate"
      class="block p-5 bg-[var(--color-v-teal)] text-white rounded-xl hover:opacity-90 transition-opacity"
    >
      <p class="text-lg font-bold mb-1">✨ Auto</p>
      <p class="text-sm opacity-90">Write a plot → Claude generates everything</p>
    </a>
    <div class="block p-5 bg-white border-2 border-[var(--color-v-teal)] rounded-xl">
      <p class="text-lg font-bold text-[var(--color-v-dark)] mb-1">✏️ Manual</p>
      <p class="text-sm text-[var(--color-v-gray)]">Fill in fields yourself — for custom stories</p>
    </div>
  </div>

  <!-- Form Card -->
  <div class="bg-white rounded-xl border border-gray-100 p-8 max-w-3xl">
    <form id="createStoryForm" class="space-y-6">
      <!-- Video Selection -->
      <div>
        <label for="video_id" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
          Video <span class="text-red-500">*</span>
        </label>
        <select
          id="video_id"
          name="video_id"
          required
          class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
        >
          <option value="">Select a video</option>
          {videos?.map(v => (
            <option value={v.id} selected={v.id === videoId}>
              {v.title}
            </option>
          ))}
        </select>
      </div>

      <!-- Story Number -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="story_number" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
            Story Number <span class="text-red-500">*</span>
          </label>
          <input
            type="number"
            id="story_number"
            name="story_number"
            min="1"
            required
            placeholder="e.g., 1"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
          />
        </div>

        <!-- Title -->
        <div>
          <label for="title" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
            Title
          </label>
          <input
            type="text"
            id="title"
            name="title"
            placeholder="Story title (optional)"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
          />
        </div>
      </div>

      <!-- Lead Character -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="lead_character" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
            Lead Character <span class="text-red-500">*</span>
          </label>
          <select
            id="lead_character"
            name="lead_character"
            required
            class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
          >
            <option value="">Select character</option>
            <option value="luna">Luna the Fox (Self-Awareness)</option>
            <option value="benny">Benny the Bear (Self-Regulation)</option>
            <option value="mia">Mia the Bunny (Social Skills)</option>
            <option value="toby">Toby the Turtle (Responsible Decisions)</option>
            <option value="zoe">Zoe the Bird (Social Awareness)</option>
          </select>
        </div>

        <!-- Primary Competency (Auto-set) -->
        <div>
          <label for="primary_competency" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
            Primary Competency <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="primary_competency"
            name="primary_competency"
            readonly
            placeholder="Auto-set based on character"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg bg-gray-50 text-[var(--color-v-gray)]"
          />
        </div>
      </div>

      <!-- SEL Tool Modeled -->
      <div>
        <label for="sel_tool_modeled" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
          SEL Tool Modeled
        </label>
        <input
          type="text"
          id="sel_tool_modeled"
          name="sel_tool_modeled"
          placeholder="e.g., Deep breathing, Gratitude journaling"
          class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
        />
      </div>

      <!-- Key Phrase -->
      <div>
        <label for="key_phrase" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
          Key Phrase
        </label>
        <input
          type="text"
          id="key_phrase"
          name="key_phrase"
          placeholder="Memorable phrase from the story"
          class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
        />
      </div>

      <!-- Situation Description -->
      <div>
        <label for="situation_description" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
          Situation Description
        </label>
        <textarea
          id="situation_description"
          name="situation_description"
          rows="3"
          placeholder="What is the SEL situation or challenge in this story?"
          class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
        ></textarea>
      </div>

      <!-- Duration -->
      <div>
        <label for="duration_minutes" class="block text-sm font-semibold text-[var(--color-v-dark)] mb-2">
          Duration (minutes) <span class="text-red-500">*</span>
        </label>
        <input
          type="number"
          id="duration_minutes"
          name="duration_minutes"
          min="1"
          max="30"
          value="5"
          required
          class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-v-teal)]"
        />
      </div>

      <!-- Submit buttons -->
      <div class="flex gap-4 pt-4">
        <button
          type="submit"
          class="px-6 py-2 bg-[var(--color-v-teal)] text-white rounded-lg font-medium hover:opacity-90 transition-opacity"
        >
          Create Story
        </button>
        <a
          href="/dashboard/stories"
          class="px-6 py-2 border border-gray-200 text-[var(--color-v-dark)] rounded-lg font-medium hover:bg-gray-50 transition-colors"
        >
          Cancel
        </a>
      </div>
    </form>
  </div>
</DashboardLayout>

<script>
  const characterSelect = document.getElementById('lead_character') as HTMLSelectElement;
  const competencyInput = document.getElementById('primary_competency') as HTMLInputElement;
  const createStoryForm = document.getElementById('createStoryForm') as HTMLFormElement;
  const videoIdSelect = document.getElementById('video_id') as HTMLSelectElement;

  // Character to competency mapping
  const characterCompetencyMap: Record<string, string> = {
    luna: 'Self-Awareness',
    benny: 'Self-Regulation',
    mia: 'Social Skills',
    toby: 'Responsible Decisions',
    zoe: 'Social Awareness',
  };

  // Auto-set competency when character changes
  characterSelect.addEventListener('change', (e) => {
    const selected = (e.target as HTMLSelectElement).value;
    competencyInput.value = characterCompetencyMap[selected] || '';
  });

  // Form submission
  createStoryForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(createStoryForm);
    const leadCharacter = formData.get('lead_character') as string;

    // Map competency label back to key
    const competencyMap: Record<string, string> = {
      'Self-Awareness': 'self_awareness',
      'Self-Regulation': 'self_regulation',
      'Social Skills': 'social_skills',
      'Responsible Decisions': 'responsible_decisions',
      'Social Awareness': 'social_awareness',
    };

    const body = {
      video_id: formData.get('video_id'),
      story_number: parseInt(formData.get('story_number') as string),
      title: formData.get('title') || null,
      lead_character: leadCharacter,
      primary_competency: competencyMap[characterCompetencyMap[leadCharacter]],
      sel_tool_modeled: formData.get('sel_tool_modeled') || null,
      key_phrase: formData.get('key_phrase') || null,
      situation_description: formData.get('situation_description') || null,
      duration_minutes: parseInt(formData.get('duration_minutes') as string),
    };

    try {
      const response = await fetch('/api/stories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (!response.ok) {
        const error = await response.json();
        alert('Error creating story: ' + (error.error || 'Unknown error'));
        return;
      }

      const result = await response.json();
      alert('Story created! Redirecting...');
      window.location.href = `/dashboard/stories/${result.data.id}`;
    } catch (error) {
      alert('Error: ' + (error instanceof Error ? error.message : 'Unknown error'));
    }
  });
</script>
