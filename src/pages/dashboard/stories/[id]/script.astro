---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { BEAT_LABELS, BEAT_COLORS, CHARACTER_LABELS, COMPETENCY_LABELS } from '@/lib/helpers';
import type { BeatType } from '@/lib/database.types';

const supabase = Astro.locals.supabase;
const { id } = Astro.params;

const { data: story } = await supabase
  .from('stories')
  .select(`
    *,
    beats: story_beats(*),
    videos (id, title, child_name, child_age, primary_competency, narrator_opening, narrator_closing)
  `)
  .eq('id', id)
  .single();

const savedImagePrompts: string[] = (story as any)?.image_prompts || [];
const savedVideoPrompts: string[] = (story as any)?.video_prompts || [];
const savedBookText: string = (story as any)?.book_text || '';

if (!story) {
  return new Response('Story not found', { status: 404 });
}

const beatOrder: BeatType[] = ['hook', 'context', 'the_moment', 'the_reaction', 'the_bridge', 'the_shift', 'the_glow'];
const beats = beatOrder.map(bt => {
  const existing = (story.beats || []).find((b: any) => b.beat === bt);
  return { beat: bt, ...(existing || {}) };
});

const hasContent = beats.some((b: any) => b.content);
const characterLabel = CHARACTER_LABELS[story.lead_character as any] || story.lead_character;
const competencyLabel = COMPETENCY_LABELS[story.primary_competency as any] || story.primary_competency;

// Build narrator script with cumulative timestamps
function formatTime(totalSeconds: number): string {
  const m = Math.floor(totalSeconds / 60);
  const s = totalSeconds % 60;
  return `${m}:${String(s).padStart(2, '0')}`;
}

const BEAT_LABELS_SHORT: Record<string, string> = {
  hook: 'HOOK', context: 'CONTEXT', the_moment: 'THE MOMENT',
  the_reaction: 'THE REACTION', the_bridge: 'THE BRIDGE',
  the_shift: 'THE SHIFT', the_glow: 'THE GLOW',
};

interface NarratorLine {
  timestamp: string;
  label: string;
  text: string;
}

const narratorLines: NarratorLine[] = [];
let cumulativeSeconds = 0;

if (story.videos?.narrator_opening) {
  narratorLines.push({ timestamp: '0:00', label: 'OPENING', text: story.videos.narrator_opening });
}

for (const beat of beats) {
  if ((beat as any).narrator_line) {
    narratorLines.push({
      timestamp: formatTime(cumulativeSeconds),
      label: BEAT_LABELS_SHORT[beat.beat] || beat.beat.toUpperCase(),
      text: (beat as any).narrator_line,
    });
  }
  cumulativeSeconds += (beat as any).duration_seconds || 0;
}

if (story.videos?.narrator_closing) {
  narratorLines.push({ timestamp: formatTime(cumulativeSeconds), label: 'CLOSING', text: story.videos.narrator_closing });
}

const hasNarratorScript = narratorLines.length > 0;
---

<DashboardLayout title={`Script — ${story.title}`}>
  <!-- Back -->
  <div class="mb-6 flex items-center justify-between">
    <a href={`/dashboard/stories/${id}`} class="text-sm text-[var(--color-v-teal)] hover:underline">
      ← Back to Story
    </a>
    {story.videos?.id && (
      <a href={`/dashboard/videos/${story.videos.id}`} class="text-sm text-[var(--color-v-gray)] hover:underline">
        {story.videos.title}
      </a>
    )}
  </div>

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[var(--color-v-dark)]" style="font-family: var(--font-display)">
      {story.story_number}. {story.title}
    </h1>
    <div class="flex gap-3 mt-2 flex-wrap text-sm text-[var(--color-v-gray)]">
      <span>{characterLabel}</span>
      <span>·</span>
      <span>{competencyLabel}</span>
      {story.sel_tool_modeled && <><span>·</span><span>{story.sel_tool_modeled}</span></>}
      {story.videos?.child_name && <><span>·</span><span>Child: {story.videos.child_name}</span></>}
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
    <!-- Left: Narrator Script + Full script -->
    <div class="lg:col-span-3 space-y-6">

      <!-- Narrator Script -->
      {hasNarratorScript && (
        <div class="bg-[var(--color-v-dark)] rounded-xl p-8 text-white">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h2 class="text-lg font-semibold">🎙 Narrator Script</h2>
              <p class="text-xs text-gray-400 mt-1">Read aloud in sequence — timestamps indicate when each line starts</p>
            </div>
            <button
              id="copyNarratorBtn"
              class="text-xs px-3 py-1.5 border border-gray-500 text-gray-300 rounded-lg hover:border-white hover:text-white transition-all"
            >
              Copy Script
            </button>
          </div>
          <div class="space-y-6" id="narratorLines">
            {narratorLines.map((line) => (
              <div class="flex gap-4">
                <div class="shrink-0 text-right w-12">
                  <span class="text-xs font-mono text-[var(--color-v-teal)] font-bold">{line.timestamp}</span>
                </div>
                <div class="border-l border-gray-600 pl-4 pb-2">
                  <p class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">{line.label}</p>
                  <p class="text-base leading-relaxed text-gray-100 italic">"{line.text}"</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {!hasNarratorScript && (
        <div class="bg-gray-50 border border-dashed border-gray-200 rounded-xl p-6 text-center">
          <p class="text-sm text-[var(--color-v-gray)]">No narrator lines yet. Add <code class="text-xs bg-gray-100 px-1 rounded">narrator_line</code> in beats or <code class="text-xs bg-gray-100 px-1 rounded">narrator_opening/closing</code> in the video.</p>
        </div>
      )}

      <!-- Book Story -->
      <div class="bg-white rounded-xl border border-gray-100 p-8">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-lg font-semibold text-[var(--color-v-dark)]">📖 Book Story</h2>
            <p class="text-xs text-[var(--color-v-gray)] mt-1">Polished prose version for publishing</p>
          </div>
          <div class="flex gap-2">
            {savedBookText && (
              <button id="copyBookBtn" class="text-xs px-3 py-1.5 border border-[var(--color-v-teal)] text-[var(--color-v-teal)] rounded-lg hover:bg-[var(--color-v-teal)] hover:text-white transition-all">
                Copy
              </button>
            )}
            <button id="generateBookBtn" class="text-xs px-3 py-1.5 bg-[var(--color-v-teal)] text-white rounded-lg hover:opacity-90 transition-opacity">
              {savedBookText ? 'Regenerate' : '✨ Generate'}
            </button>
          </div>
        </div>

        <div id="bookLoading" class="hidden text-center py-8">
          <div class="inline-block w-8 h-8 border-4 border-[var(--color-v-teal)] border-t-transparent rounded-full animate-spin mb-3"></div>
          <p class="text-sm text-[var(--color-v-gray)]">Claude is writing the story...</p>
        </div>

        <div id="bookContent">
          {savedBookText ? (
            <div id="bookText" class="prose prose-sm max-w-none text-[var(--color-v-dark)] leading-relaxed whitespace-pre-wrap font-serif text-base">
              {savedBookText}
            </div>
          ) : (
            <div id="bookEmpty" class="text-center py-8">
              <p class="text-sm text-[var(--color-v-gray)]">No book story generated yet.</p>
            </div>
          )}
        </div>
      </div>

      <!-- Full script read view -->
      <div class="bg-white rounded-xl border border-gray-100 p-8">
        <h2 class="text-lg font-semibold text-[var(--color-v-dark)] mb-6">Full Script</h2>

        {!hasContent && (
          <div class="text-center py-12">
            <p class="text-[var(--color-v-gray)] mb-4">No beats content yet.</p>
            <a href={`/dashboard/stories/${id}`} class="text-[var(--color-v-teal)] hover:underline text-sm">
              Go fill in the beats →
            </a>
          </div>
        )}

        <div class="space-y-8">
          {beats.map((beat: any) => {
            const label = BEAT_LABELS[beat.beat as BeatType];
            const colors = BEAT_COLORS[beat.beat as BeatType];
            if (!beat.content && !beat.narrator_line) return null;
            return (
              <div class={`rounded-lg border-l-4 pl-5 py-1 ${colors}`}>
                <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-v-gray)] mb-2">{label}</p>
                {beat.narrator_line && (
                  <p class="text-sm italic text-[var(--color-v-gray)] mb-2">
                    🎙 {beat.narrator_line}
                  </p>
                )}
                {beat.content && (
                  <p class="text-sm text-[var(--color-v-dark)] leading-relaxed whitespace-pre-wrap">
                    {beat.content}
                  </p>
                )}
                {beat.emotion_energy && (
                  <p class="text-xs text-[var(--color-v-gray)] mt-2">⚡ {beat.emotion_energy}</p>
                )}
                {beat.visual_notes && (
                  <p class="text-xs text-[var(--color-v-gray)] mt-1">🎬 {beat.visual_notes}</p>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
    </div>

    <!-- Right: Prompt Generator -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-100 p-6 sticky top-8">
        <h2 class="text-lg font-semibold text-[var(--color-v-dark)] mb-1">Prompt Generator</h2>
        <p class="text-xs text-[var(--color-v-gray)] mb-6">Generate ~20 prompts from story beats</p>

        <!-- Type selector -->
        <div class="flex gap-2 mb-6">
          <button
            id="btnImage"
            class="flex-1 py-2 px-3 rounded-lg text-sm font-medium border-2 border-[var(--color-v-teal)] bg-[var(--color-v-teal)] text-white transition-all"
          >
            📸 Image (nanobanana)
          </button>
          <button
            id="btnVideo"
            class="flex-1 py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 text-[var(--color-v-gray)] transition-all"
          >
            🎥 Video (Grok)
          </button>
        </div>

        <button
          id="generateBtn"
          class="w-full py-3 bg-[var(--color-v-teal)] text-white rounded-lg font-medium hover:opacity-90 transition-opacity mb-6 disabled:opacity-50"
        >
          Generate Prompts
        </button>

        <!-- Loading state -->
        <div id="loadingState" class="hidden text-center py-8">
          <div class="inline-block w-8 h-8 border-4 border-[var(--color-v-teal)] border-t-transparent rounded-full animate-spin mb-3"></div>
          <p class="text-sm text-[var(--color-v-gray)]">Generating prompts with Claude...</p>
        </div>

        <!-- Results -->
        <div id="resultsSection" class={savedImagePrompts.length > 0 ? '' : 'hidden'}>
          <div class="flex items-center justify-between mb-3">
            <p id="promptCount" class="text-sm font-semibold text-[var(--color-v-dark)]">
              {savedImagePrompts.length > 0 ? `${savedImagePrompts.length} prompts saved` : ''}
            </p>
            <button
              id="copyAllBtn"
              class="text-xs px-3 py-1 border border-[var(--color-v-teal)] text-[var(--color-v-teal)] rounded-lg hover:bg-[var(--color-v-teal)] hover:text-white transition-all"
            >
              Copy All
            </button>
          </div>
          <div id="promptsList" class="space-y-3 max-h-[60vh] overflow-y-auto pr-1">
            {savedImagePrompts.map((prompt, idx) => (
              <div class="bg-gray-50 rounded-lg p-3 relative group">
                <p class="text-xs text-[var(--color-v-gray)] font-semibold mb-1">#{idx + 1}</p>
                <p class="text-xs text-[var(--color-v-dark)] leading-relaxed">{prompt}</p>
                <button
                  class="copy-btn absolute top-2 right-2 opacity-0 group-hover:opacity-100 text-xs px-2 py-1 bg-white border border-gray-200 rounded hover:border-[var(--color-v-teal)] transition-all"
                  data-prompt={prompt}
                >Copy</button>
              </div>
            ))}
          </div>
        </div>

        <!-- Error state -->
        <div id="errorState" class="hidden">
          <p id="errorMsg" class="text-sm text-red-600 bg-red-50 rounded-lg p-3"></p>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script define:vars={{ storyId: id, savedImagePrompts, savedVideoPrompts, narratorLines, storyTitle: story.title, savedBookText }}>
  let selectedType = 'image';

  function renderSavedPrompts(prompts) {
    const list = document.getElementById('promptsList');
    const results = document.getElementById('resultsSection');
    const countEl = document.getElementById('promptCount');
    if (!prompts || prompts.length === 0) {
      results.classList.add('hidden');
      return;
    }
    list.innerHTML = '';
    prompts.forEach((prompt, idx) => {
      const div = document.createElement('div');
      div.className = 'bg-gray-50 rounded-lg p-3 relative group';
      div.innerHTML = `
        <p class="text-xs text-[var(--color-v-gray)] font-semibold mb-1">#${idx + 1}</p>
        <p class="text-xs text-[var(--color-v-dark)] leading-relaxed">${prompt}</p>
        <button class="copy-btn absolute top-2 right-2 opacity-0 group-hover:opacity-100 text-xs px-2 py-1 bg-white border border-gray-200 rounded hover:border-[var(--color-v-teal)] transition-all" data-prompt="${prompt.replace(/"/g, '&quot;')}">Copy</button>
      `;
      list.appendChild(div);
    });
    list.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(this.getAttribute('data-prompt'));
        this.textContent = 'Copied!';
        setTimeout(() => { this.textContent = 'Copy'; }, 1500);
      });
    });
    countEl.textContent = `${prompts.length} prompts saved`;
    results.classList.remove('hidden');

    document.getElementById('copyAllBtn').onclick = () => {
      navigator.clipboard.writeText(prompts.join('\n\n'));
      const btn = document.getElementById('copyAllBtn');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy All'; }, 2000);
    };
  }

  function selectType(type) {
    selectedType = type;
    const btnImage = document.getElementById('btnImage');
    const btnVideo = document.getElementById('btnVideo');
    if (type === 'image') {
      btnImage.className = 'flex-1 py-2 px-3 rounded-lg text-sm font-medium border-2 border-[var(--color-v-teal)] bg-[var(--color-v-teal)] text-white transition-all';
      btnVideo.className = 'flex-1 py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 text-gray-500 transition-all';
      renderSavedPrompts(savedImagePrompts);
    } else {
      btnVideo.className = 'flex-1 py-2 px-3 rounded-lg text-sm font-medium border-2 border-[var(--color-v-teal)] bg-[var(--color-v-teal)] text-white transition-all';
      btnImage.className = 'flex-1 py-2 px-3 rounded-lg text-sm font-medium border-2 border-gray-200 text-gray-500 transition-all';
      renderSavedPrompts(savedVideoPrompts);
    }
  }

  // Book Story
  let currentBookText = savedBookText;

  document.getElementById('generateBookBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('generateBookBtn') as HTMLButtonElement;
    const loading = document.getElementById('bookLoading')!;
    const content = document.getElementById('bookContent')!;

    btn.disabled = true;
    btn.textContent = 'Writing...';
    loading.classList.remove('hidden');
    content.classList.add('hidden');

    try {
      const response = await fetch(`/api/stories/${storyId}/book`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.error || 'Generation failed');

      currentBookText = data.book_text;
      content.innerHTML = `<div id="bookText" class="prose prose-sm max-w-none text-[var(--color-v-dark)] leading-relaxed whitespace-pre-wrap font-serif text-base">${data.book_text.replace(/</g, '&lt;')}</div>`;
      content.classList.remove('hidden');

      const copyBtn = document.getElementById('copyBookBtn');
      if (copyBtn) {
        copyBtn.classList.remove('hidden');
      } else {
        const newCopyBtn = document.createElement('button');
        newCopyBtn.id = 'copyBookBtn';
        newCopyBtn.className = 'text-xs px-3 py-1.5 border border-[var(--color-v-teal)] text-[var(--color-v-teal)] rounded-lg hover:bg-[var(--color-v-teal)] hover:text-white transition-all';
        newCopyBtn.textContent = 'Copy';
        btn.parentElement?.insertBefore(newCopyBtn, btn);
        newCopyBtn.addEventListener('click', () => copyBook(newCopyBtn));
      }
      btn.textContent = 'Regenerate';
    } catch (err) {
      content.innerHTML = `<p class="text-sm text-red-600">${(err as Error).message}</p>`;
      content.classList.remove('hidden');
      btn.textContent = currentBookText ? 'Regenerate' : '✨ Generate';
    } finally {
      btn.disabled = false;
      loading.classList.add('hidden');
    }
  });

  function copyBook(btn: HTMLButtonElement) {
    if (!currentBookText) return;
    navigator.clipboard.writeText(currentBookText);
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
  }

  document.getElementById('copyBookBtn')?.addEventListener('click', function() {
    copyBook(this as HTMLButtonElement);
  });

  // Copy Narrator Script
  const copyNarratorBtn = document.getElementById('copyNarratorBtn');
  if (copyNarratorBtn && narratorLines.length > 0) {
    copyNarratorBtn.addEventListener('click', () => {
      const text = `NARRATOR SCRIPT — "${storyTitle}"\n\n` +
        narratorLines.map(l => `[${l.timestamp} — ${l.label}]\n"${l.text}"`).join('\n\n');
      navigator.clipboard.writeText(text);
      copyNarratorBtn.textContent = 'Copied!';
      setTimeout(() => { copyNarratorBtn.textContent = 'Copy Script'; }, 2000);
    });
  }

  document.getElementById('btnImage').addEventListener('click', () => selectType('image'));
  document.getElementById('btnVideo').addEventListener('click', () => selectType('video'));

  document.getElementById('generateBtn').addEventListener('click', async () => {
    const btn = document.getElementById('generateBtn');
    const loading = document.getElementById('loadingState');
    const results = document.getElementById('resultsSection');
    const errorState = document.getElementById('errorState');

    btn.disabled = true;
    loading.classList.remove('hidden');
    results.classList.add('hidden');
    errorState.classList.add('hidden');

    try {
      const response = await fetch(`/api/stories/${storyId}/prompts`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: selectedType }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Generation failed');
      }

      const prompts = data.prompts;
      document.getElementById('promptCount').textContent = `${prompts.length} prompts`;

      const list = document.getElementById('promptsList');
      list.innerHTML = '';

      prompts.forEach((prompt, idx) => {
        const div = document.createElement('div');
        div.className = 'bg-gray-50 rounded-lg p-3 relative group';
        div.innerHTML = `
          <p class="text-xs text-[var(--color-v-gray)] font-semibold mb-1">#${idx + 1}</p>
          <p class="text-xs text-[var(--color-v-dark)] leading-relaxed">${prompt}</p>
          <button
            class="copy-btn absolute top-2 right-2 opacity-0 group-hover:opacity-100 text-xs px-2 py-1 bg-white border border-gray-200 rounded hover:border-[var(--color-v-teal)] transition-all"
            data-prompt="${prompt.replace(/"/g, '&quot;')}"
          >Copy</button>
        `;
        list.appendChild(div);
      });

      list.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          navigator.clipboard.writeText(this.getAttribute('data-prompt'));
          this.textContent = 'Copied!';
          setTimeout(() => { this.textContent = 'Copy'; }, 1500);
        });
      });

      document.getElementById('copyAllBtn').onclick = () => {
        const allText = prompts.join('\n\n');
        navigator.clipboard.writeText(allText);
        const btn = document.getElementById('copyAllBtn');
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy All'; }, 2000);
      };

      results.classList.remove('hidden');
    } catch (err) {
      document.getElementById('errorMsg').textContent = err.message;
      errorState.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      loading.classList.add('hidden');
    }
  });
</script>
