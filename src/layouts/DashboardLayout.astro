---
import '../styles/global.css';

interface BreadcrumbItem { label: string; href?: string; }
const { title = 'Virtuelia Dashboard', breadcrumb = [] } = Astro.props as { title?: string; breadcrumb?: BreadcrumbItem[] };
const user = Astro.locals.user;

const navItems = [
  { href: '/dashboard', label: 'Overview', icon: '◆' },
  { href: '/dashboard/videos', label: 'Videos', icon: '▶' },
  { href: '/dashboard/stories', label: 'Stories', icon: '◇' },
  { href: '/dashboard/characters', label: 'Characters', icon: '★' },
  { href: '/dashboard/countries', label: 'Countries', icon: '●' },
  { href: '/dashboard/traits', label: 'SEL Traits', icon: '♥' },
  { href: '/dashboard/settings', label: 'Settings', icon: '⚙' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Virtuelia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-[var(--color-v-warm)]">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-[var(--color-v-dark)] text-white flex flex-col fixed h-full z-10">
      <!-- Logo -->
      <div class="p-6 border-b border-white/10">
        <a href="/dashboard" class="flex items-center gap-3">
          <span class="text-2xl font-bold text-[var(--color-v-teal)]" style="font-family: var(--font-display)">V</span>
          <span class="text-lg font-semibold" style="font-family: var(--font-display)">Virtuelia</span>
        </a>
        <p class="text-xs text-white/40 mt-1">Story Building Dashboard</p>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 py-4">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'flex items-center gap-3 px-6 py-3 text-sm transition-all',
              currentPath === item.href || (item.href !== '/dashboard' && currentPath.startsWith(item.href))
                ? 'bg-[var(--color-v-teal)]/20 text-[var(--color-v-teal-light)] border-r-2 border-[var(--color-v-teal)]'
                : 'text-white/60 hover:text-white hover:bg-white/5'
            ]}
          >
            <span class="text-base w-5 text-center">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>

      <!-- User -->
      <div class="p-4 border-t border-white/10">
        <div class="flex items-center gap-3">
          {user?.user_metadata?.avatar_url ? (
            <img src={user.user_metadata.avatar_url} alt="" class="w-8 h-8 rounded-full" />
          ) : (
            <div class="w-8 h-8 rounded-full bg-[var(--color-v-teal)] flex items-center justify-center text-xs font-bold">
              {user?.email?.charAt(0).toUpperCase() || '?'}
            </div>
          )}
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium truncate">{user?.user_metadata?.full_name || user?.email || 'User'}</p>
            <p class="text-xs text-white/40 truncate">{user?.email}</p>
          </div>
        </div>
        <form action="/api/auth/logout" method="POST" class="mt-3">
          <button type="submit" class="text-xs text-white/40 hover:text-white transition-colors">
            Sign out
          </button>
        </form>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 ml-64">
      {breadcrumb.length > 0 && (
        <div class="px-8 pt-6 pb-0">
          <nav class="flex items-center gap-2 text-sm text-[var(--color-v-gray)]">
            {breadcrumb.map((item, i) => (
              <>
                {i > 0 && <span class="text-gray-300">/</span>}
                {item.href
                  ? <a href={item.href} class="hover:text-[var(--color-v-teal)] transition-colors truncate max-w-[180px]">{item.label}</a>
                  : <span class="text-[var(--color-v-dark)] font-medium truncate max-w-[200px]">{item.label}</span>
                }
              </>
            ))}
          </nav>
        </div>
      )}
      <div class="p-8">
        <slot />
      </div>
    </main>
  </div>

  <script>
    // GSAP page animations
    import gsap from 'gsap';

    document.addEventListener('astro:page-load', () => {
      gsap.from('main > div > *', {
        y: 20,
        opacity: 0,
        duration: 0.4,
        stagger: 0.05,
        ease: 'power2.out',
      });
    });
  </script>
</body>
</html>
